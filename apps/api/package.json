{
  "name": "@sentinel/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node --env-file .env dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx --env-file .env src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentinel/shared": "workspace:*",
    "fastify": "^5.0.0",
    "nanoid": "^5.0.0",
    "p-limit": "^6.0.0",
    "p-timeout": "^6.0.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "prom-client": "^15.0.0",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.1"
  }
}
